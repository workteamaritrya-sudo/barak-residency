rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: is the user authenticated?
    function i() {
      return request.auth != null;
    }
    
    // Helper: get the current user's role
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    // 1. Users Collection
    match /users/{email} {
      allow read: if i() && (request.auth.token.email == email || getRole() == 'Admin');
      allow write: if i() && getRole() == 'Admin';
    }

    // 2. Menu Items
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if i() && getRole() == 'Admin';
    }

    // 3. Orders & Service Requests — all authenticated staff
    match /orders/{orderId} {
      allow read, write: if true; 
    }
    
    match /serviceRequests/{reqId} {
      allow read, write: if true;
    }

    // 4. Rooms (Reception Logic)
    match /rooms/{roomNum} {
      allow read, write: if i();
    }
    
    // 5. Billing & Sales (Sensitive)
    match /ledger/{docId} {
      allow read, write: if i() && getRole() == 'Admin';
    }
    match /salesHistory/{docId} {
      allow read, write: if i() && getRole() == 'Admin';
    }

    // 6. Staff Profiles
    // Staff can read & write their OWN profile. Admin can read all.
    match /staffProfiles/{uid} {
      allow read: if i() && (request.auth.uid == uid || getRole() == 'Admin');
      allow write: if i() && request.auth.uid == uid;
    }

    // 7. Staff Attendance Records
    // Staff writes their own records. Any authenticated user can read (admin reporting).
    match /staffAttendance/{recordId} {
      allow read: if i();
      allow write: if i() && recordId.matches(request.auth.uid + '_.*');
    }

    // 8. Checkout Clearance
    // Reception creates. Staff updates (clear / issue). All auth users can read live.
    match /checkoutClearance/{docId} {
      allow read:   if i();
      allow create: if i();
      allow update: if i();
    }

    // 9. Notifications (cross-portal alerts)
    match /notifications/{docId} {
      allow read, write: if i();
    }

    // 10. Guests & Billing (Reception)
    match /guests/{guestId} {
      allow read, write: if i();
    }

    // 11. Settings (availability, etc.)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if i();
    }

    // 12. Police logs
    match /police_logs/{docId} {
      allow read, write: if i();
    }
  }
}
